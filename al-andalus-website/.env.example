# Payload CMS
# Local dev:
DATABASE_URI=file:./database.db
#
# Staging/production (Hostinger): use a path OUTSIDE the git deploy folder so pushes
# do not overwrite admin users, CMS edits, or form submissions. Example:
# DATABASE_URI=file:/home/u123456/domains/yourdomain.com/private/data/database.db
# Create that folder once on the server and keep PAYLOAD_SECRET identical across deploys.
# Optional Turso/libSQL auth token
# DATABASE_AUTH_TOKEN=

# REQUIRED in production: 32+ character random string
PAYLOAD_SECRET=change-me-to-a-long-random-string-at-least-32

# After bilingual/CMS schema changes on Hostinger: set true once, redeploy, then set false.
# Without this, /admin can crash with: Cannot destructure property 'admin'
# PAYLOAD_DATABASE_PUSH=true
# PAYLOAD_DATABASE_PUSH=false

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Contact form inbox (defaults to Site Settings email, then info@alandalus-iq.com)
# CONTACT_TO_EMAIL=info@alandalus-iq.com

# SMTP — required for real email delivery of contact form messages
# Without these, messages still save to the dashboard; email is logged to the server console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_ADDRESS=info@alandalus-iq.com
# SMTP_FROM_NAME=Al-Andalus Insurance
# SMTP_SKIP_VERIFY=true

# Seed endpoint (GET /api/seed) — disabled unless BOTH are set
# ALLOW_SEED=true
# SEED_SECRET=generate-a-long-random-string
# PARTNERS_LOGOS_DIR=./public/partners-logos

# Optional: enable GraphQL playground in production (default: off)
# ENABLE_GRAPHQL_PLAYGROUND=true
