# Payload CMS
DATABASE_URI=file:./database.db
# Optional Turso/libSQL auth token
# DATABASE_AUTH_TOKEN=

# REQUIRED in production: 32+ character random string
PAYLOAD_SECRET=change-me-to-a-long-random-string-at-least-32

# Set to "true" only when you intentionally want schema push in production
# PAYLOAD_DATABASE_PUSH=true

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Seed endpoint (GET /api/seed) — disabled unless BOTH are set
# ALLOW_SEED=true
# SEED_SECRET=generate-a-long-random-string
# PARTNERS_LOGOS_DIR=./public/partners-logos

# Optional: enable GraphQL playground in production (default: off)
# ENABLE_GRAPHQL_PLAYGROUND=true
